{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EVE Metrade",
  "version": "0.1.0",
  "identifier": "com.local.evemetrade",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "EVE Metrade",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
